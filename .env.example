# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Airtable
# API key from airtable.com/account
AIRTABLE_API_KEY=your-airtable-api-key
# Base ID from the URL: airtable.com/appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=your-base-id

# Airtable Tables Required:
# - Users: id, name, email, passwordHash, role, profilePhoto, niche, businessStage, bio, stripeCustomerId, createdAt
# - MembershipPlans: id, name, description, price, interval, stripeProductId, stripePriceId, features, isActive
# - Subscriptions: id, userId, planId, status, stripeSubscriptionId, currentPeriodEnd
# - Purchases: id, userId, productId, productType, amount, status, stripePaymentIntentId, createdAt
# - Courses: id, title, description, thumbnail, isPublished, accessLevel, order
# - Modules: id, courseId, title, order
# - Lessons: id, moduleId, courseId, title, content, videoUrl, lessonType, order, duration, resourceUrl, resourceName
# - UserProgress: id, userId, lessonId, completedAt
# - Classes: id, title, description, dateTime, coachName, meetingLink, replayLoomId, programmeId, isPublished, category
# - CommunityPosts: id, userId, userName, userPhoto, content, category, isPinned, createdAt, likesCount
# - Comments: id, postId, userId, userName, content, createdAt
# - Messages: id, fromUserId, toUserId, fromName, content, isRead, createdAt
# - Resources: id, title, description, fileUrl, category, accessLevel, createdAt, fileType
# - Notifications: id, userId, type, content, isRead, createdAt, link

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Next public (exposed to browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
